// Tests recursive function calls.
// TODO: Tail call optimization (TCO) is not yet implemented in template codegen.
// When TCO is added, this test should be updated to verify the optimization
// (e.g., factorial(100000, 1) without stack overflow).

fn factorial(n: int, acc: int): int =>
  if n <= 1 => return acc
  return factorial(n - 1, acc * n)

fn main(): void =>
  assert(factorial(5, 1) == 120, "expected 5! to be 120")
  assert(factorial(1, 1) == 1, "expected 1! to be 1")
  assert(factorial(0, 1) == 1, "expected 0! to be 1")
