// Code Generation Test: Global with function
//
// Tests that a function can read global string variables and can modify
// global handles.

var greeting: str = "Hello"
var message: str = ""

fn process_greeting(): int =>
    // function accesses global 'greeting' and mutates global 'message'
    message = greeting + " World"
    return len(greeting)

fn main(): int =>
    println("Global with function test:")
    var result: int = process_greeting()
    println(message)
    println($"Greeting length: {result}")
    println("PASS")
    return 0
