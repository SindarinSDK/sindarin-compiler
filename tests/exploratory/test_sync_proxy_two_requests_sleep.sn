// Closer reproducer for Issue #41 using strings and native sleep.
// The skynet proxy uses Time.sleep(1) in spin-waits and passes
// string payloads via non-sync shared variables.

@source "test_sync_proxy_two_requests_sleep.sn.c"

@alias "sn_sleep_ms"
native fn sleep_ms(ms: int): void

sync var reqReady: int = 0
sync var respReady: int = 0
var request: str = ""
var response: str = ""
var msgType: int = 0
sync var done: int = 0

fn proxy(): int =>
  while done == 0 =>
    while reqReady == 0 && done == 0 =>
      sleep_ms(1)
    if done == 1 =>
      break
    // Echo back the request with the message type prepended
    response = $"type={msgType}:{request}"
    reqReady = 0
    respReady = 1
  return 0

fn main(): void =>
  var handle: int = & proxy()
  sleep_ms(50)

  var cycle: int = 0
  while cycle < 5 =>
    // Request 1: "store" operation
    msgType = 1
    request = $"store-{cycle}"
    respReady = 0
    reqReady = 1
    while respReady == 0 =>
      sleep_ms(1)
    var resp1: str = response

    // Request 2: "search" operation
    msgType = 2
    request = $"search-{cycle}"
    respReady = 0
    reqReady = 1
    while respReady == 0 =>
      sleep_ms(1)
    var resp2: str = response

    println($"Cycle {cycle}: {resp1} | {resp2}")
    cycle = cycle + 1
    // Long sleep between cycles (like skynet's cycleIntervalMs)
    sleep_ms(100)

  println("SUCCESS: 5 cycles with 2 string requests each completed")
  done = 1
