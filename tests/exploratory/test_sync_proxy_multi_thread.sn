// Reproducer for Issue #41 with multiple concurrent proxy threads.
// Skynet has 5 proxy threads (graph, model, executor, reward, memory)
// all using the same sync var pattern. This test checks whether
// multiple concurrent proxies cause the main loop to stall after
// two requests on one proxy within the same loop iteration.

@source "test_sync_proxy_multi_thread.sn.c"

@alias "sn_sleep_ms"
native fn sleep_ms(ms: int): void

// Proxy A (like graph-engine) — 1 request per cycle
var reqA: str = ""
var respA: str = ""
sync var reqReadyA: int = 0
sync var respReadyA: int = 0

// Proxy B (like memory) — 2 requests per cycle
var reqB: str = ""
var respB: str = ""
sync var reqReadyB: int = 0
sync var respReadyB: int = 0
var msgTypeB: int = 0

fn proxyA(): int =>
  while true =>
    while reqReadyA == 0 =>
      sleep_ms(1)
    respA = $"A:{reqA}"
    reqReadyA = 0
    respReadyA = 1
  return 0

fn proxyB(): int =>
  while true =>
    while reqReadyB == 0 =>
      sleep_ms(1)
    respB = $"B{msgTypeB}:{reqB}"
    reqReadyB = 0
    respReadyB = 1
  return 0

fn callA(payload: str): str =>
  reqA = payload
  respReadyA = 0
  reqReadyA = 1
  while respReadyA == 0 =>
    sleep_ms(1)
  return respA

fn callB(kind: int, payload: str): str =>
  msgTypeB = kind
  reqB = payload
  respReadyB = 0
  reqReadyB = 1
  while respReadyB == 0 =>
    sleep_ms(1)
  return respB

fn main(): void =>
  var hA: int = & proxyA()
  var hB: int = & proxyB()
  sleep_ms(50)

  var cycle: int = 0
  while cycle < 5 =>
    // Step 1: one request on proxy A
    var r1: str = callA($"graph-{cycle}")

    // Step 2: TWO requests on proxy B (store + search in same cycle)
    var r2: str = callB(1, $"store-{cycle}")
    var r3: str = callB(2, $"search-{cycle}")

    println($"Cycle {cycle}: {r1} | {r2} | {r3}")
    cycle = cycle + 1

  println("SUCCESS: 5 cycles with multi-proxy completed")
