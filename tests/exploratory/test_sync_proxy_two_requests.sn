// Reproducer for Issue #41: cycle loop thread stops iterating after two
// consecutive request-response pairs through a sync var proxy in one cycle.
//
// Pattern: a "proxy" thread spin-waits on reqReady, processes the request,
// signals respReady. The main thread sends TWO requests per loop iteration.
//
// Expected: 5 cycles complete, each with 2 request-response pairs.
// Bug:      cycle 0 completes but cycle 1 never starts — the while loop
// body never executes again.

sync var reqReady: int = 0
sync var respReady: int = 0
var request: int = 0
var response: int = 0

fn proxy(): int =>
  while true =>
    while reqReady == 0 =>
      var spin: int = 0
    // Process the request
    response = request * 2
    reqReady = 0
    respReady = 1
  return 0

fn main(): void =>
  var handle: int = & proxy()

  // Give proxy thread time to start spinning
  var warmup: int = 0
  for var i: int = 0; i < 1000000; i++ =>
    warmup = warmup + 1

  var cycle: int = 0
  while cycle < 5 =>
    // Request 1
    request = cycle * 10 + 1
    respReady = 0
    reqReady = 1
    while respReady == 0 =>
      var spin: int = 0
    var resp1: int = response

    // Request 2
    request = cycle * 10 + 2
    respReady = 0
    reqReady = 1
    while respReady == 0 =>
      var spin: int = 0
    var resp2: int = response

    print($"Cycle {cycle}: resp1={resp1}, resp2={resp2}\n")
    cycle = cycle + 1

  print("SUCCESS: 5 cycles with 2 requests each completed\n")
