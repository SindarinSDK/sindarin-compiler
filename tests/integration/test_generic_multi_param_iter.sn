# Test: Multi-param generic struct with iterator returning another multi-param generic
# Exercises: resolve_generic_instantiation with multiple TYPE_STRUCT forward-ref args
# Also tests proper cleanup of returned structs with heap fields from next()

struct Entry < K, V > =>
  key: K
  value: V

struct EntryIter < K, V > =>
  keys: K[]
  values: V[]
  index: int

  fn hasNext(): bool =>
    return self.index < len(self.keys)

  fn next(): Entry < K, V > =>
    var k: K = self.keys[self.index]
    var v: V = self.values[self.index]
    self.index = self.index + 1
    return Entry < K, V > {key: k, value: v}

struct SimpleMap < K, V > =>
  keys: K[]
  values: V[]

  fn put(key: K, value: V): void =>
    self.keys.push(key)
    self.values.push(value)

  fn size(): int =>
    return len(self.keys)

  fn iter(): EntryIter < K, V > =>
    return EntryIter < K, V > {keys: self.keys, values: self.values, index: 0}

fn main(): int =>
  # Test 1: SimpleMap<int, int> with iteration
  var m: SimpleMap < int, int > = SimpleMap < int, int > {keys: {}, values: {}}
  m.put(1, 100)
  m.put(2, 200)
  m.put(3, 300)
  if m.size() != 3 =>
    print("FAIL: map size should be 3\n")
    return 1
  var ksum: int = 0
  var vsum: int = 0
  for entry in m =>
    ksum = ksum + entry.key
    vsum = vsum + entry.value
  if ksum != 6 =>
    print("FAIL: key sum should be 6\n")
    return 1
  if vsum != 600 =>
    print("FAIL: value sum should be 600\n")
    return 1
  print("Test 1 passed: SimpleMap<int, int> iteration\n")

  # Test 2: SimpleMap<str, int> with string keys (tests cleanup of Entry with str field)
  var m2: SimpleMap < str, int > = SimpleMap < str, int > {keys: {}, values: {}}
  m2.put("alice", 95)
  m2.put("bob", 82)
  m2.put("carol", 91)
  var total: int = 0
  for entry in m2 =>
    total = total + entry.value
  if total != 268 =>
    print("FAIL: total should be 268\n")
    return 1
  print("Test 2 passed: SimpleMap<str, int> iteration\n")

  # Test 3: SimpleMap<int, str> with string values
  var m3: SimpleMap < int, str > = SimpleMap < int, str > {keys: {}, values: {}}
  m3.put(1, "one")
  m3.put(2, "two")
  var ksum3: int = 0
  for entry in m3 =>
    ksum3 = ksum3 + entry.key
  if ksum3 != 3 =>
    print("FAIL: key sum should be 3\n")
    return 1
  print("Test 3 passed: SimpleMap<int, str> iteration\n")

  print("All multi-param generic iterator tests passed!\n")
  return 0
