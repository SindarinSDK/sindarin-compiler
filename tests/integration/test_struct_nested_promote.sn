# Test: Nested struct with string fields must survive cross-function return.
# When a function returns a struct containing a nested struct with str fields,
# the string fields inside the nested struct must remain valid in the caller.

struct Address =>
  street: str
  city: str

struct Person =>
  name: str
  age: int
  address: Address

fn createPerson(): Person =>
  var addr: Address = Address {
    street: "123 Main St",
    city: "Springfield"
  }
  var p: Person = Person {
    name: "Alice",
    age: 30,
    address: addr
  }
  return p

fn main(): void =>
  var p: Person = createPerson()

  # Access all fields - nested struct strings must be valid
  print($"Name: {p.name}\n")
  print($"Age: {p.age}\n")
  print($"Street: {p.address.street}\n")
  print($"City: {p.address.city}\n")

  if p.name == "Alice" && p.age == 30 =>
    if p.address.street == "123 Main St" && p.address.city == "Springfield" =>
      print("PASS\n")
      return
  print("FAIL\n")
