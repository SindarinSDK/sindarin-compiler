# Test: ref-struct fields corrupted when parent struct returned from function
# Reproduces compiler issue #31
# A regular struct containing as-ref struct fields should preserve
# field values when returned from a function.

struct Handle as ref =>
  tag: int
  payload: int

struct Container =>
  h1: Handle
  h2: Handle

fn make_container(): Container =>
  var a: Handle = {
    tag: 10,
    payload: 100
  }
  var b: Handle = {
    tag: 20,
    payload: 200
  }
  print($"Inside: a.tag={a.tag}, a.payload={a.payload}\n")
  print($"Inside: b.tag={b.tag}, b.payload={b.payload}\n")
  return Container {
    h1: a,
    h2: b
  }

fn main(): int =>
  # Baseline: direct ref struct use
  var h: Handle = {
    tag: 1,
    payload: 2
  }
  print($"Direct: tag={h.tag}, payload={h.payload}\n")

  # Baseline: same-scope struct literal
  var x: Handle = {
    tag: 30,
    payload: 300
  }
  var y: Handle = {
    tag: 40,
    payload: 400
  }
  var local: Container = {
    h1: x,
    h2: y
  }
  print($"Local h1: tag={local.h1.tag}, payload={local.h1.payload}\n")
  print($"Local h2: tag={local.h2.tag}, payload={local.h2.payload}\n")

  # Returned from function — this should work but previously corrupted fields
  var c: Container = make_container()
  print($"Returned h1: tag={c.h1.tag}, payload={c.h1.payload}\n")
  print($"Returned h2: tag={c.h2.tag}, payload={c.h2.payload}\n")
  return 0
