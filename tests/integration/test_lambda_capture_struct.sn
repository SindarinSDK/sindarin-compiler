// Regression: a lambda captures both a native pointer (db-like) AND a
// user-struct (metrics-client-like) from outer scope. The user-struct has
// string fields, an array field, and int fields, and is created via a
// static factory. Two background threads take the user struct by value
// (the compiler inserts a deep copy into the thread args). The lambda is
// then passed to a higher-order function in a SEPARATE module which
// invokes it many times.
//
// The lambda captures the struct by value; the closure environment must
// hold its own deep copy (see __closure_N_struct_cleanup__ in the
// generated C). Without that, the closure shares heap pointers with
// main's local and ASAN reports a use-after-free once main's sn_auto
// cleanup runs.
//
// Passing a value-struct `as ref` to a thread spawn is intentionally a
// compile error (see tests/integration/errors/test_thread_spawn_as_ref_composite.sn)
// because the raw pointer into main's stack frame cannot safely cross a
// thread boundary. Skynet services that want shared mutable state across
// threads should declare the struct as `struct X as ref => ...` so that
// retain/release manages lifetime instead.

import "lib/higher_order"

# Stand-in for QuicConnection — opaque native-style pointer.
struct DbHandle =>
  id: int

struct Captured =>
  source: str
  addr: str
  buffer: int[]
  maxBatchSize: int
  flushIntervalMs: int

  static fn create(source: str, addr: str, batchSize: int, flushInterval: int): Captured =>
    var emptyBuf: int[] = {}
    return Captured {
      source: source,
      addr: addr,
      buffer: emptyBuf,
      maxBatchSize: batchSize,
      flushIntervalMs: flushInterval
    }

# Takes by value (thread spawn deep-copies into its own args struct).
# Mirrors a flush-loop service task that reads the captured config.
fn flushLoop(c: Captured): int =>
  # Touch the fields so the read is real, but do not print (would race
  # with main's output and make the test non-deterministic on success).
  var len: int = c.source.length + c.addr.length
  return len

# Takes by value (so a deep copy occurs at call site). Mirrors acceptLoop's
# `metrics: MetricsClient` parameter that gets copy-passed in skynet.
fn listenLoop(d: DbHandle, c: Captured): int =>
  return c.maxBatchSize + c.flushIntervalMs

# Mirrors handleWorkStream — takes the captured user-struct by value
# (Sindarin's calling convention turns this into a pointer parameter in C).
# Returns 1 on each call so invokeIt can detect corruption: any returned
# value other than 1 means a captured field was wrong.
fn helper(d: DbHandle, c: Captured): int =>
  if c.source == "hello" && c.addr == "world" && c.maxBatchSize == 200 && c.flushIntervalMs == 10000 =>
    return 1
  return 0

fn main(): int =>
  var db: DbHandle = { id: 7 }
  var c: Captured = Captured.create("hello", "world", 200, 10000)

  var h1: int = & flushLoop(c)
  h1 ~

  var h2: int = & listenLoop(db, c)
  h2 ~

  print($"main: source={c.source} addr={c.addr} batch={c.maxBatchSize} interval={c.flushIntervalMs} bufLen={len(c.buffer)}\n")

  invokeIt(fn(x: int): int => helper(db, c))

  return 0
