# Integration test for issue #34: Heap corruption when native struct as ref
# is created and used in a loop.
#
# Tests that the compiler correctly retains refcounted types when:
# 1. A local sn_auto variable is initialized from an existing reference
# 2. Multiple handles are created and destroyed each loop iteration
# 3. Handles are shared between input and output of function calls
# 4. Handles are reassigned within a loop

#pragma source "test_native_struct_ref_loop_cleanup_helper.c"

native struct Handle as ref =>
  _id: int

  static fn create(id: int): Handle =>
    return handle_create(id)

native fn handle_create(id: int): Handle

# Test 1: Multiple handles created and destroyed each iteration
fn test_basic(): void =>
  for var i: int = 0; i < 5; i++ =>
    var a: Handle = Handle.create(i * 4)
    var b: Handle = Handle.create(i * 4 + 1)
    var c: Handle = Handle.create(i * 4 + 2)
    var d: Handle = Handle.create(i * 4 + 3)
    println($"basic {i}: a={a._id} b={b._id} c={c._id} d={d._id}")
  println("test_basic: PASS")

# Test 2: Same handle stored in multiple variables (shared ref)
fn test_shared_handle(): void =>
  for var i: int = 0; i < 5; i++ =>
    var h: Handle = Handle.create(i * 100)
    var a: Handle = h
    var b: Handle = h
    println($"shared {i}: h={h._id} a={a._id} b={b._id}")
  println("test_shared_handle: PASS")

# Test 3: Handle passed to function, returned in new context (cross-scope sharing)
fn transform(input: Handle): Handle =>
  var local: Handle = input
  return Handle.create(local._id * 10)

fn test_cross_scope(): void =>
  for var i: int = 0; i < 5; i++ =>
    var h: Handle = Handle.create(i + 1)
    var r: Handle = transform(h)
    println($"cross {i}: h={h._id} r={r._id}")
  println("test_cross_scope: PASS")

# Test 4: Handle reassignment in loop
fn test_reassign(): void =>
  for var i: int = 0; i < 5; i++ =>
    var h: Handle = Handle.create(i)
    h = Handle.create(i + 100)
    println($"reassign {i}: h={h._id}")
  println("test_reassign: PASS")

fn main(): void =>
  test_basic()
  test_shared_handle()
  test_cross_scope()
  test_reassign()
  println("done")
