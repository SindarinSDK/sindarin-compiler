// Test: multi-line return with struct literal

struct Config =>
  host: str
  port: int
  debug: bool

fn makeConfig(): Config =>
  return Config {
    host: "localhost",
    port: 8080,
    debug: true
  }

fn main(): void =>
  var c: Config = makeConfig()
  println($"{c.host}:{c.port} debug={c.debug}")
