# Test: fire-and-forget thread with native as-ref struct.
# Without the fix, sn_auto cleanup frees the struct while
# the detached thread is still using it (heap-use-after-free).
# Fix: codegen nullifies the local after spawn (needs_move).
#
# The thread reads from the struct (triggers ASAN if freed) then
# disposes it. Main uses a joinable spawn to wait, then prints "done".
# If ASAN is enabled and the fix is missing, the test crashes.

#pragma source "test_thread_fire_forget_asref.c"

@alias "RtResource"
native struct Resource as ref =>
    _handle: int
    @alias "resource_create"
    static native fn create(id: int): Resource
    @alias "resource_read_silent"
    native fn readSilent(): int
    @alias "resource_dispose"
    native fn dispose(): void

fn handleResource(r: Resource): void =>
    var result: int = r.readSilent()
    r.dispose()

fn main(): void =>
    var r: Resource = Resource.create(0)
    &handleResource(r)

    # Wait via a joinable spawn to give the fire-and-forget thread time
    var x: int = &waitWork()
    x!
    println("done")

fn waitWork(): int =>
    var s: int = 0
    for i in 0..100000 =>
        s = s + 1
    return s
