// Test str[][] struct field across method boundaries (Issue #17)
// Inner arrays must survive after the populating method returns

struct CsvTable =>
  rows: str[][]
  cursor: int

  static fn create(): CsvTable =>
    return CsvTable {
      rows: {},
      cursor: 0
    }

  fn load(): void =>
    var line1: str = "a,b,c"
    var line2: str = "d,e,f"
    var line3: str = "g,h,i"
    self.rows.push(line1.split(","))
    self.rows.push(line2.split(","))
    self.rows.push(line3.split(","))
    println($"loaded {self.rows.length} rows")

  fn name(): str => "csv"

  fn nextRow(): str[] =>
    if self.cursor >= self.rows.length =>
      return {}
    var row: str[] = self.rows[self.cursor]
    self.cursor = self.cursor + 1
    return row

fn main(): void =>
  var table: CsvTable = CsvTable.create()
  table.load()
  println(table.name())
  var row1: str[] = table.nextRow()
  println($"{row1[0]},{row1[1]},{row1[2]}")
  var row2: str[] = table.nextRow()
  println($"{row2[0]},{row2[1]},{row2[2]}")
  var row3: str[] = table.nextRow()
  println($"{row3[0]},{row3[1]},{row3[2]}")
