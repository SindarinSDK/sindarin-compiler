typedef struct {
{{#each args}}
    {{c_type type}} {{name}};
{{/each}}
    int _padding;
} __ThreadArgs_{{thread_id}}__;

static void *__thread_wrapper_{{thread_id}}__(void *arg) {
    SnThread *__th__ = (SnThread *)arg;
{{#if has_args}}
    __ThreadArgs_{{thread_id}}__ *args = (__ThreadArgs_{{thread_id}}__ *)__th__->result;
    __ThreadArgs_{{thread_id}}__ __args_copy__ = *args;
    args = &__args_copy__;
{{/if}}
{{#if is_void}}
    __sn__{{func_name}}({{#each args}}{{#if @index}}, {{/if}}args->{{name}}{{/each}});
{{else}}
    {{c_type return_type}} __result__ = __sn__{{func_name}}({{#each args}}{{#if @index}}, {{/if}}args->{{name}}{{/each}});
    if (!__th__->result) __th__->result = calloc(1, sizeof({{c_type return_type}}));
    *({{c_type return_type}} *)__th__->result = __result__;
{{/if}}
    return NULL;
}
{{/each}}
{{#if lambdas}}
typedef struct __Closure__ {
    void *fn;
    size_t size;
} __Closure__;
{{#each lambdas}}

{{#if has_captures}}
typedef struct __closure_{{lambda_id}}__ {
    void *fn;
    size_t size;
{{#each captures}}
    {{c_type type}} {{#if is_ref}}*{{/if}}{{name}};
{{/each}}
} __closure_{{lambda_id}}__;
{{/if}}
static {{c_type return_type}} __lambda_{{lambda_id}}__(void *__closure__{{#each params}}, {{c_type type}} __sn__{{name}}{{/each}});
