{{#each threads}}
void *__thread_wrapper_{{thread_id}}__(void *arg) {
    SnThread *__th__ = (SnThread *)arg;
{{#if has_args}}
    __ThreadArgs_{{thread_id}}__ *args = (__ThreadArgs_{{thread_id}}__ *)__th__->result;
    __ThreadArgs_{{thread_id}}__ __args_copy__ = *args;
    args = &__args_copy__;
{{/if}}
{{#if is_void}}
    __sn__{{func_name}}({{#each args}}{{#if @index}}, {{/if}}args->{{name}}{{/each}});
{{#each args}}{{#if is_fn_ref_arg}}    free(args->{{name}});
{{/if}}{{/each}}{{else}}
    {{c_type return_type}} __result__ = __sn__{{func_name}}({{#each args}}{{#if @index}}, {{/if}}args->{{name}}{{/each}});
{{#each args}}{{#if is_fn_ref_arg}}    free(args->{{name}});
{{/if}}{{/each}}{{#if has_args}}    free(__th__->result); __th__->result = NULL;
{{/if}}    if (!__th__->result) __th__->result = calloc(1, sizeof({{c_type return_type}}));
    *({{c_type return_type}} *)__th__->result = {{#if (eq return_type.kind "string")}}__result__ ? strdup(__result__) : NULL{{else}}__result__{{/if}};
{{/if}}
    return NULL;
}
{{/each}}
{{#each fn_wrappers}}
{{c_type return_type}} __fn_wrap_{{wrapper_id}}__(void *__closure__{{#each param_types}}, {{c_type this}} __p{{@index}}__{{/each}}) {
    (void)__closure__;
    {{#unless (eq return_type.kind "void")}}return {{/unless}}{{#if is_native}}{{target_name}}{{else}}__sn__{{target_name}}{{/if}}({{#each param_types}}{{#if @index}}, {{/if}}__p{{@index}}__{{/each}});
}
{{/each}}
{{#with module}}{{#if has_main}}
{{#if has_main_args}}int main(int argc, char **argv) {
    SnArray *__sn__args = sn_array_new(sizeof(char *), argc);
    __sn__args->elem_tag = SN_TAG_STRING;
    for (int __i__ = 0; __i__ < argc; __i__++) {
        char *__s__ = strdup(argv[__i__]);
        sn_array_push(__sn__args, &__s__);
    }
{{else}}int main() {
{{/if}}
{{#each ../all_globals}}{{#if is_deferred}}    __sn__{{name}} = {{#if needs_strdup}}strdup({{> expr initializer}}){{else}}{{> expr initializer}}{{/if}};
{{/if}}{{/each}}{{#each ../functions}}{{#if (eq name "main")}}{{#each body}}
    {{> stmt this}}{{/each}}{{/if}}{{/each}}{{#each ../all_globals}}{{#if needs_cleanup}}{{#if (eq cleanup_kind "str")}}    free(__sn__{{name}});
{{else}}{{#if (eq cleanup_kind "arr")}}    sn_cleanup_array(&__sn__{{name}});
{{else}}{{#if (eq cleanup_kind "release")}}    __sn__{{type.name}}_release(&__sn__{{name}});
{{else}}{{#if (eq cleanup_kind "val_cleanup")}}    __sn__{{type.name}}_cleanup(&__sn__{{name}});
{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/each}}{{#if has_main_args}}    sn_cleanup_array(&__sn__args);
{{/if}}{{#unless main_returns}}    return 0;
{{/unless}}
}{{/if}}{{/with}}
